{
  "name": "@sakspilot/desktop",
  "version": "0.0.20",
  "private": true,
  "description": "Sakspilot desktop-agent - tray-app som logger aktivt vindu og kobler til sak. Cross-platform (Windows + macOS + Linux).",
  "author": {
    "name": "Helene Åsheim Grønberg",
    "email": "helene@helene.cloud"
  },
  "main": "src/main.js",
  "scripts": {
    "postinstall": "node scripts/generate-icon.js",
    "start": "node start-electron.js",
    "dev": "node start-electron.js --dev",
    "build:exe": "node build-portable.js",
    "build:exe:mac": "node build-portable.js --platform=darwin --arch=x64",
    "build:exe:mac-arm": "node build-portable.js --platform=darwin --arch=arm64",
    "build:exe:linux": "node build-portable.js --platform=linux --arch=x64",
    "build:installer": "electron-builder --win --x64 --config.electronVersion=30.5.1",
    "poc": "node src/poc-logger.js",
    "poc:fast": "node src/poc-logger.js --interval=3 --duration=120",
    "poc:matching": "node src/poc-logger.js --rules",
    "diagnose": "node src/diagnose.js"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "electron-store": "^8.2.0",
    "xlsx": "^0.18.5"
  },
  "optionalDependencies": {
    "active-win": "^8.2.0"
  },
  "devDependencies": {
    "@electron/packager": "^18.3.6",
    "electron": "^30.5.1",
    "electron-builder": "^25.0.5",
    "png-to-ico": "^3.0.1",
    "png2icons": "^2.0.1"
  },
  "build": {
    "appId": "no.helene.sakspilot",
    "productName": "Sakspilot",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/tray-icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
