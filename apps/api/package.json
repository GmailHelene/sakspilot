{
  "name": "@sakspilot/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate --schema=../../packages/db/prisma/schema.prisma && tsc",
    "start": "tsx src/index.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run src/__tests__/mva.test.ts src/__tests__/invoiceMath.test.ts src/__tests__/invoiceLineItems.test.ts src/__tests__/crypto.test.ts",
    "test:integration": "vitest run --fileParallelism=false src/__tests__/auth.test.ts src/__tests__/saker.test.ts src/__tests__/share.test.ts",
    "test:watch": "vitest",
    "job:daily-automations": "tsx src/jobs/dailyAutomationTrigger.ts",
    "job:db-backup": "tsx src/jobs/dbBackup.ts",
    "job:onboarding-drip": "tsx src/jobs/onboardingDrip.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "@prisma/client": "^5.14.0",
    "@sakspilot/db": "file:../../packages/db",
    "@sakspilot/shared": "file:../../packages/shared",
    "@sentry/node": "^8.55.2",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.5.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.18.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.7"
  }
}
