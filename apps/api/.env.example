# Sakspilot API — eksempel .env (kopier til .env og fyll inn ekte verdier)

# Server
PORT=8001
NODE_ENV=development

# Database — Neon (anbefalt) eller Railway Postgres
#
# NEON (gratis 0.5GB, EU-region Frankfurt):
#   1. Opprett prosjekt på https://neon.tech (region: EU Frankfurt)
#   2. Connection details → kopier "Pooled connection" som DATABASE_URL
#   3. Kopier "Direct connection" som DIRECT_URL
# Eksempel:
#   DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.eu-central-1.aws.neon.tech/sakspilot?sslmode=require"
#   DIRECT_URL="postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/sakspilot?sslmode=require"
#
# RAILWAY POSTGRES (alternativ, $5/mnd inkl. i Hobby-plan):
#   1. Railway prosjekt → New → Database → PostgreSQL
#   2. Variables → kopier DATABASE_URL
#   3. Sett DIRECT_URL = samme verdi
DATABASE_URL=""
DIRECT_URL=""

# JWT
# Generer en sterk hemmelig (minst 64 tegn): node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="erstatt-meg-med-en-sterk-hemmelig-fra-crypto-randomBytes"
JWT_EXPIRES_IN=8h

# Frontend (for CORS og e-postlenker)
FRONTEND_URL="http://localhost:3001"

# E-post (Brevo HTTP API — gratis 300/dag)
# BREVO_API_KEY=""

# Microsoft Graph (Outlook) — fylles inn i fase 2
# AZURE_CLIENT_ID=""
# AZURE_CLIENT_SECRET=""
# AZURE_TENANT_ID="common"

# Sentry feillogging (valgfri)
# SENTRY_DSN=""
