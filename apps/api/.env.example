# Sakspilot API — eksempel .env (kopier til .env og fyll inn ekte verdier)

# Server
PORT=8001
NODE_ENV=development

# Database — Neon (anbefalt) eller Railway Postgres
#
# NEON (gratis 0.5GB, EU-region Frankfurt):
#   1. Opprett prosjekt på https://neon.tech (region: EU Frankfurt)
#   2. Connection details → kopier "Pooled connection" som DATABASE_URL
#   3. Kopier "Direct connection" som DIRECT_URL
# Eksempel:
#   DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.eu-central-1.aws.neon.tech/sakspilot?sslmode=require"
#   DIRECT_URL="postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/sakspilot?sslmode=require"
#
# RAILWAY POSTGRES (alternativ, $5/mnd inkl. i Hobby-plan):
#   1. Railway prosjekt → New → Database → PostgreSQL
#   2. Variables → kopier DATABASE_URL
#   3. Sett DIRECT_URL = samme verdi
DATABASE_URL=""
DIRECT_URL=""

# JWT
# Generer en sterk hemmelig (minst 64 tegn): node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="erstatt-meg-med-en-sterk-hemmelig-fra-crypto-randomBytes"
JWT_EXPIRES_IN=8h

# Frontend (for CORS og e-postlenker)
FRONTEND_URL="http://localhost:3001"

# E-post via SMTP (Brevo, Resend, Postmark osv — alle støtter SMTP)
# Brevo (gratis 300 mails/dag):
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_USER=<din-brevo-bruker-email>
#   SMTP_PASS=<xsmtpsib-... fra Brevo SMTP & API → SMTP-fanen>
#   EMAIL_FROM=<verifisert-avsender@dittdomene.no>
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@sakspilot.no"

# Microsoft Graph (Outlook) — fylles inn i fase 2
# AZURE_CLIENT_ID=""
# AZURE_CLIENT_SECRET=""
# AZURE_TENANT_ID="common"

# Fiken OAuth (når vi går fra PAT-flyt til full OAuth — Q3 2026)
# Genereres via fiken.no → Innstillinger → API/integrasjoner → Mine apper
# FIKEN_CLIENT_ID=""
# FIKEN_CLIENT_SECRET=""
# FIKEN_REDIRECT_URI="https://api.sakspilot.no/accounting/fiken/oauth/callback"

# AI-provider (anthropic = default, bedrock = fremtidig EU-residency)
AI_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""
# Hvis AI_PROVIDER=bedrock:
# AWS_REGION="eu-west-1"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""

# Sentry feillogging (valgfri)
# Opprett prosjekt på https://sentry.io → New Project → Express (Node.js)
# Kopier DSN fra prosjekt-settings → Client Keys (DSN)
# SENTRY_DSN="https://abc123@o12345.ingest.sentry.io/67890"
