// Sakspilot — Prisma-skjema
// Workspace for selvstendig næringsdrivende.
// Kobler til Postgres på Supabase (EU/Irland).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ────────────────────────────────────────────────────────────────
// Enums
// ────────────────────────────────────────────────────────────────

enum Plan {
  solo
  pro
  team
}

enum UserRole {
  owner       // eier av organisasjonen (har alltid full tilgang)
  member      // vanlig bruker i team-plan
  admin       // har tilgang til adminkonsoll i Sakspilot HQ (oss)
}

enum SakStatus {
  ikke_pabegynt   // sak opprettet, ingen arbeid logget
  pagaaende       // aktiv, jobbes med
  venter_kunde    // venter på kunde
  venter_3part    // venter på kommune / motpart / leverandør
  ferdig          // levert
  arkivert        // gammel sak, skjult fra hovedvisning
}

enum MatchingRuleType {
  title          // matcher mot vindustittel
  path           // matcher mot filsti
  app            // matcher mot applikasjonsnavn
  email          // matcher mot e-postavsender/mottaker
}

enum TimeEntrySource {
  auto           // automatisk fra desktop-agent
  manual         // brukeren la inn manuelt
  edited         // automatisk, men brukeren endret etterpå
}

enum InvoiceStatus {
  draft          // utkast — kan endres
  exported       // sendt til regnskap eller CSV
  cancelled
}

enum InvoiceExportTarget {
  csv
  tripletex
  fiken
  poweroffice
  conta
  visma
}

enum AgentPlatform {
  windows
  macos
  linux
}

/// Foresporsel-status (UI viser "Forespørsel"): lead-pipeline fra første
/// kontakt til konvertering. Bevisst kort og oversiktlig — kan utvides
/// hvis vi senere trenger mer granular tracking (f.eks. proposalSent).
/// NB: Prisma-identifikatorer må være ASCII (ingen æ/ø/å), derfor
/// "Foresporsel" i koden men "forespørsler" i DB-tabellnavn (via @@map).
enum ForesporselStatus {
  ny              // nettopp mottatt, ikke behandlet
  i_dialog        // pågående samtaler / tilbud sendt
  vunnet          // konvertert til klient + sak
  tapt            // kunden valgte noen andre / ble aldri kunde
  arkivert        // gammel, ikke aktuell
}

// ────────────────────────────────────────────────────────────────
// Modeller
// ────────────────────────────────────────────────────────────────

model Organization {
  id              String   @id @default(uuid())
  name            String
  plan            Plan     @default(solo)
  billingEmail    String?  @map("billing_email")
  orgNumber       String?  @map("org_number")       // norsk organisasjonsnummer
  // Adresse + bankkonto — brukes på faktura-PDF (route: /invoice-pdf/sak/:id).
  // Alle felter er valgfrie; PDF-en bruker placeholder hvis null.
  address         String?
  postalCode      String?  @map("postal_code")
  city            String?
  bankAccount     String?  @map("bank_account")     // kontonr for utbetaling, vises på faktura-PDF
  defaultHourlyRate Int?   @map("default_hourly_rate") // kr/t — kan overstyres per sak
  timezone        String   @default("Europe/Oslo")
  /// Pilotperiode-utløp. Mens denne er i fremtiden er produktet GRATIS
  /// uansett trial-status på User. Settes manuelt (eller via seed).
  /// Default: alle nye org i pilotfasen settes til 2026-12-31 av registreringskoden.
  pilotUntil      DateTime? @map("pilot_until")
  /// AI-kvote per måned. Resettes når aiMonthStartedAt er > 30 dager gammel.
  /// Default-kvote: 500 kall/mnd (hard cap). Pilot-orgs (pilotUntil > now)
  /// får 10x kvote = 5000. Soft warning ved 80% bruk via response header.
  aiCallsThisMonth Int      @default(0) @map("ai_calls_this_month")
  aiTokensThisMonth Int     @default(0) @map("ai_tokens_this_month") // input + output, for fremtidig cost-basert
  aiMonthStartedAt DateTime @default(now()) @map("ai_month_started_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  users    User[]
  clients  Client[]
  saker    Sak[]
  invoices Invoice[]
  auditLogs AuditLog[]
  stickyNotes StickyNote[]
  automations Automation[]
  subscription Subscription?
  fikenIntegration FikenIntegration?
  tripletexIntegration TripletexIntegration?
  feedbacks Feedback[]
  teamInvites TeamInvite[]
  customDomains CustomDomain[]
  foresporsler  Foresporsel[]
  utgifter      Utgift[]

  @@map("organizations")
}

/// Eget domene en frilanser kan koble til sin klient-portal (whitelabel).
/// Eksempel: "klienter.helenetech.no" → peker via CNAME til sakspilot.no,
/// og når en request kommer inn med Host: klienter.helenetech.no resolver
/// vi den til denne organisasjonen og overstyrer branding i portal-UI.
///
/// Sikkerhet:
///   - hostname @unique — to orgs kan ikke kreve samme domene
///   - DNS TXT-verifisering FØR vi anser domenet som verified — hindrer
///     at noen "stjeler" andres domene ved bare å oppgi det
///   - verificationToken regenereres ved hver POST /custom-domains (gammel
///     blir ugyldig)
///   - Branding-felter er null = bruk default Sakspilot-branding
model CustomDomain {
  id                String   @id @default(uuid())
  organizationId    String   @map("organization_id")
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Eksempel: "klienter.helenetech.no" — normaliseres til lowercase
  hostname          String   @unique
  /// false inntil DNS TXT-record på _sakspilot-verify.{hostname} matcher
  /// verificationToken. Hostname-resolver SKAL bare matche verified=true.
  verified          Boolean  @default(false)
  /// Random hex-streng (32 hex tegn = 16 bytes entropi). Brukeren legger
  /// denne som verdi i TXT-record. Regenereres ved re-add.
  verificationToken String   @map("verification_token")
  verifiedAt        DateTime? @map("verified_at")
  // ── Branding-overrides — alle null = bruk Sakspilot default ────────
  /// Erstatter "Sakspilot" i portal-topbar (f.eks. "Helene Tech Solutions")
  brandName         String?  @map("brand_name")
  /// Vises som tagline under brandName (f.eks. "Klient-portal")
  brandTagline      String?  @map("brand_tagline")
  /// Hex-farge som overstyrer navy-primary i portal-CSS-var
  brandPrimaryColor String?  @map("brand_primary_color")
  /// Valgfri logo (peker på fil — kan være data-URL eller absolutt URL)
  brandLogoUrl      String?  @map("brand_logo_url")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("custom_domains")
}

/// Fiken-integrasjon per organisasjon.
/// Helene bruker personal access token (PAT) i stedet for OAuth — krever ikke
/// partner-status, hver bruker autoriserer sin egen Fiken-konto.
/// Brukeren limer inn token + company-slug i /innstillinger/integrasjoner.
model FikenIntegration {
  id              String   @id @default(uuid())
  organizationId  String   @unique @map("organization_id")
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Fiken company slug (f.eks. "fiken-demo") — del av API-URL
  companySlug     String   @map("company_slug")
  /// Personal access token — kryptert med AES-256-GCM (samme som OAuth-tokens)
  encryptedToken  String   @map("encrypted_token")
  /// Når tokenet sist ble verifisert mot Fiken API
  lastVerifiedAt  DateTime? @map("last_verified_at")
  /// Hvor mange fakturaer Sakspilot har opprettet via dette tokenet
  invoicesCreated Int      @default(0) @map("invoices_created")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("fiken_integrations")
}

/// Tripletex-integrasjon per organisasjon.
/// Sakspilot er Partner hos Tripletex (Consumer Token i env-var TRIPLETEX_CONSUMER_TOKEN).
/// Hver kundes admin genererer en EmployeeToken i sin Tripletex og limer inn her.
/// Backend bygger en SessionToken (1-times levetid) dynamisk fra Consumer + Employee.
/// EmployeeToken lagres kryptert (AES-256-GCM, samme nøkkel som FikenIntegration).
model TripletexIntegration {
  id                     String   @id @default(uuid())
  organizationId         String   @unique @map("organization_id")
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Employee-token — kryptert med AES-256-GCM (samme som FikenIntegration)
  encryptedEmployeeToken String   @map("encrypted_employee_token")
  /// Tripletex Company ID — verifiseres via /v2/company API på connect
  companyId              Int?     @map("company_id")
  /// Tripletex Employee ID — settes når token verifiseres
  employeeId             Int?     @map("employee_id")
  /// Visningsnavn for selskapet (cached fra Tripletex' /company-respons)
  companyName            String?  @map("company_name")
  /// Visningsnavn for den ansatte tokenet representerer
  employeeName           String?  @map("employee_name")
  /// Sann hvis brukeren har valgt test-miljøet (api-test.tripletex.tech)
  useTestEnv             Boolean  @default(false) @map("use_test_env")
  /// Når token sist ble verifisert mot Tripletex API
  lastVerifiedAt         DateTime? @map("last_verified_at")
  /// Antall fakturaer/timer pushet via denne integrasjonen
  invoicesPushed         Int      @default(0) @map("invoices_pushed")
  hoursPushed            Int      @default(0) @map("hours_pushed")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("tripletex_integrations")
}

/// Subscription per organisasjon. Null = ingen aktiv subscription (trial eller pilot).
/// stripeSubscriptionId fylles inn ved Stripe-integrasjon (Q1-Q2 2027).
/// Frem til da: settes manuelt ved manuell fakturering via Fiken.
model Subscription {
  id              String              @id @default(uuid())
  organizationId  String              @unique @map("organization_id")
  status          SubscriptionStatus  @default(trialing)
  plan            SubscriptionPlan    @default(solo_monthly)
  currentPeriodStart DateTime         @map("current_period_start")
  currentPeriodEnd   DateTime         @map("current_period_end")
  cancelAtPeriodEnd  Boolean          @default(false) @map("cancel_at_period_end")
  // Stripe-felter (null inntil vi aktiverer Stripe Billing)
  stripeCustomerId       String?  @map("stripe_customer_id")
  stripeSubscriptionId   String?  @unique @map("stripe_subscription_id")
  stripePriceId          String?  @map("stripe_price_id")
  // Manuell faktura-flow inntil Stripe
  invoiceMethod          BillingMethod @default(manual_invoice) @map("invoice_method")
  notes                  String?       @db.Text
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

enum Profession {
  it_konsulent
  konsulent_annet
  ansvarlig_soker
  advokat
  regnskap
  designer
  arkitekt
  lege_psykolog
  annet
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  cancelled
  expired
}

enum SubscriptionPlan {
  solo_monthly      // 199 kr/mnd (planlagt)
  solo_yearly       // 1990 kr/år (planlagt)
  team_monthly      // for fremtidig 2-5 brukere
}

enum BillingMethod {
  manual_invoice    // Faktura via Fiken/Tripletex (default frem til Stripe)
  stripe
  vipps
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String?   @map("password_hash")
  name           String
  role           UserRole  @default(owner)
  organizationId String    @map("organization_id")
  hourlyRate     Int?      @map("hourly_rate")    // personlig sats — overstyrer org-default
  lastLoginAt    DateTime? @map("last_login_at")
  /// Inkrementeres ved logg-ut-alle-enheter, passordbytte, eller manuell revoke.
  /// JWT inneholder denne verdien — middleware avviser tokens med utdatert versjon.
  tokenVersion   Int       @default(0) @map("token_version")
  /// Når den gratis 14-dagers trial-perioden utløper.
  /// Settes til registrering + 14 dager. Etter dette kreves Subscription
  /// (i pilotfasen overskrives av Organization.pilotUntil).
  trialEndsAt    DateTime? @map("trial_ends_at")
  /// Brukerens bransje — settes ved første gangs onboarding.
  /// Brukes til å tilpasse default-snarveier i Launcher, og kan brukes
  /// til å filtrere agent-templates senere.
  profession     Profession? @default(annet)
  /// Reset-token for glemt-passord-flyt. SHA-256-hash av tokenet som ble
  /// e-postet. Brukeren får selve tokenet i mailen — vi lagrer kun hashen
  /// så DB-lekkasje ikke gir reset-tilgang.
  passwordResetTokenHash String?   @map("password_reset_token_hash")
  passwordResetExpiresAt DateTime? @map("password_reset_expires_at")
  /// Personlige tidsmål — null = ikke satt. Måles i timer.
  /// Brukes til progress-widget på /hjem og varsler hvis brukeren henger etter.
  weeklyHoursGoal  Int?    @map("weekly_hours_goal")
  monthlyHoursGoal Int?    @map("monthly_hours_goal")
  /// "billable" = teller kun fakturerbare timer, "total" = alle timer.
  /// Default billable — frilanseren bryr seg primært om inntektsgivende tid.
  goalType         String  @default("billable") @map("goal_type")
  /// Siste onboarding-drip-e-post som er sendt til denne brukeren.
  /// 0 = ingen sendt (welcome ikke registrert via drip), 3/7/14 = dag-N sendt.
  /// Brukes av jobs/onboardingDrip.ts for å unngå at samme bruker får samme
  /// e-post to ganger hvis cron-jobben kjører flere ganger eller hvis vinduet
  /// glipper en dag.
  lastOnboardingEmail Int? @default(0) @map("last_onboarding_email")
  /// iCal-feed-token — randomisert hex-streng (16 bytes = 32 hex tegn = 128 bits entropy).
  /// Når satt, kan brukeren abonnere på sine frister/milepæler via en URL som
  /// inneholder dette tokenet. Token er ENESTE autentisering på /ical-endepunktet,
  /// så lengden må være lang nok til at brute-force er upraktisk.
  /// Null = ingen feed generert (default). Regenereres ved POST /me/ical/generate,
  /// nullstilles ved DELETE /me/ical (kalender slutter umiddelbart å virke).
  icalToken      String?   @unique @map("ical_token")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  timeEntries  TimeEntry[]
  auditLogs    AuditLog[]
  agentSessions AgentSession[]
  graphAccount GraphAccount?
  stickyNotes  StickyNote[]
  sharedLinks  SharedSakLink[]
  preferences  UserPreferences?
  feedbacks    Feedback[]
  aiChatMessages AiChatMessage[]
  sentInvites  TeamInvite[]    @relation("InvitesSent")

  @@index([organizationId])
  @@map("users")
}

/// Cloud-synket UI-preferanser per bruker.
/// Frontend lagrer det samme som localStorage (snarveier, sites, mapper,
/// tema, hidden-nav osv) — men her i DB så det overlever ny .exe-installasjon,
/// nettleser-bytte, browser-cache-wipe, etc. Frontend skriver hver 5. sek
/// hvis noe har endret seg (debounced), og leser ved app-mount.
model UserPreferences {
  userId      String   @id @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Hele preferanse-blobben som JSON. Strukturen er { sakspilot_*: string }
  /// — verdiene matcher det som tidligere bare lå i localStorage.
  preferences Json
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("user_preferences")
}

model Client {
  id                String   @id @default(uuid())
  organizationId    String   @map("organization_id")
  name              String
  orgNumber         String?  @map("org_number")
  contactEmail      String?  @map("contact_email")
  contactPhone      String?  @map("contact_phone")
  address           String?
  defaultHourlyRate Int?     @map("default_hourly_rate") // overstyrer org-default for denne klienten
  notes             String?  @db.Text
  archived          Boolean  @default(false)
  // ── Klient-portal (login for klient) ──────────────────────────
  // null hvis klienten ikke har fått portal-tilgang (det vanlige).
  // Settes når frilanseren inviterer klienten OG klienten aksepterer + setter passord.
  // Uavhengig av User.email (forskjellige tabeller, ulikt scope i JWT).
  email             String?  @unique
  passwordHash      String?  @map("password_hash")
  portalEnabled     Boolean  @default(false) @map("portal_enabled")
  lastLoginAt       DateTime? @map("last_login_at")
  // Bumpes ved passordbytte / revoke — JWT inneholder denne, middleware avviser
  // tokens med utdatert versjon (samme mønster som User.tokenVersion).
  tokenVersion      Int      @default(0) @map("token_version")
  // Reset-passord-flow for klient. SHA-256-hash av tokenet i e-posten.
  passwordResetTokenHash String?   @map("password_reset_token_hash")
  passwordResetExpiresAt DateTime? @map("password_reset_expires_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  saker        Sak[]
  portalInvite ClientPortalInvite?

  @@index([organizationId])
  @@map("clients")
}

/// Foresporsel = inkommen lead/inquiry FØR den blir en betalende klient.
/// Lever utenfor Client-tabellen fordi en lead ikke nødvendigvis har
/// org-nummer / kontakt-info komplett enda, og fordi vi vil måle
/// konverteringsrate (vunnet / (vunnet+tapt)) som meningsfull statistikk.
///
/// Når status → vunnet: vi konverterer til Client (manuelt via UI-knapp).
/// convertedToClientId peker tilbake til den genererte klienten.
///
/// NB: Norsk "Forespørsel" i UI, men ASCII-navn "Foresporsel" i Prisma
/// fordi Prisma-identifikatorer ikke støtter æ/ø/å.
model Foresporsel {
  id                     String              @id @default(uuid())
  organizationId         String              @map("organization_id")
  organization           Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Kontaktnavn — personnavn ELLER firmanavn (vi vet ikke alltid forskjell på lead-stadiet)
  name                   String
  /// Kontakt-epost — frivillig, men minst én av (email, phone) bør finnes
  email                  String?
  phone                  String?
  /// Hvor leaden kom fra: "facebook-gruppe X", "henvist av Y", "google-søk", "linkedin", "befaring"…
  /// Fritekst, ingen enum — for fleksibilitet (analytics kan grupperes senere)
  source                 String?
  /// Beskrivelse av hva de spør om / behov — kopiert fra e-post, meldingsfeltet på nettsiden, eller notater
  message                String?             @db.Text
  status                 ForesporselStatus   @default(ny)
  /// Estimert verdi i NOK hvis leaden konverterer (for pipeline-statistikk)
  estimatedValue         Int?                @map("estimated_value")
  /// Når regner du med å lukke denne (vunnet eller tapt)? Brukes til "ventende pipeline"-rapport
  expectedCloseDate      DateTime?           @map("expected_close_date")
  /// Når leaden faktisk ble vunnet/tapt
  closedAt               DateTime?           @map("closed_at")
  /// Hvis konvertert: peker på opprettet Client
  convertedToClientId    String?             @map("converted_to_client_id")
  /// Hvis konvertert: peker på første opprettet Sak
  convertedToSakId       String?             @map("converted_to_sak_id")
  notes                  String?             @db.Text
  /// Ekstern ID fra import-kilde (f.eks. "lead_steinar_001" fra portal-hub).
  /// Brukes til idempotent upsert i seed-scriptene: hvis externalId finnes,
  /// hopper vi over for å bevare brukerens manuelle redigeringer i web.
  externalId             String?             @map("external_id")
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")

  @@unique([organizationId, externalId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@map("foresporsler")
}

/// Utgift = bedriftsutgift (kjøp, abonnement, tjeneste, kilometergodtgjørelse).
/// Brukes til regnskap, MVA-rapport og innsikt i kostnadsbasen.
/// Vedlegg (kvittering) lagres som URL — kan peke på S3, Drive, eller lokal fil
/// referert via /assets/api-router (kommer senere).
model Utgift {
  id              String       @id @default(uuid())
  organizationId  String       @map("organization_id")
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Dato for utgiften (når den ble pådratt — ikke når registrert)
  dato            DateTime
  /// Hva utgiften gjaldt — fritekst, vises i lister og rapporter
  beskrivelse     String
  /// Beløp inkl. MVA, i kroner. Bruker Decimal pga finansdata.
  belopInkMva     Decimal      @map("belop_ink_mva") @db.Decimal(12, 2)
  /// MVA-sats brukt (0 = ingen MVA, 25 = ordinær). Frivillig — null = ikke håndtert
  mvaSats         Int?         @map("mva_sats")
  /// Kategori (drift, kontor, reise, abonnement, programvare, annet) — fritekst
  /// for fleksibilitet. UI tilbyr forslag basert på tidligere bruk.
  kategori        String?
  /// Leverandør (Adobe, Google, NSB, etc.) — fritekst
  leverandor      String?
  /// URL til kvittering (PDF/bilde). Null = ingen kvittering vedlagt.
  kvitteringUrl   String?      @map("kvittering_url")
  notes           String?      @db.Text
  /// Ekstern ID fra import-kilde — idempotent upsert i seed.
  externalId      String?      @map("external_id")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@unique([organizationId, externalId])
  @@index([organizationId, dato])
  @@index([organizationId, kategori])
  @@map("utgifter")
}

/// Invitasjon fra frilanser til klient om å aktivere klient-portal-login.
/// Tokenet sendes på e-post; vi lagrer bcrypt-hashen så DB-lekkasje ikke
/// gir aksept-tilgang. Én aktiv invite per klient (clientId @unique). Hvis
/// frilanseren inviterer på nytt, slettes/overskrives gammel rad.
model ClientPortalInvite {
  id          String   @id @default(uuid())
  clientId    String   @unique @map("client_id")
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tokenHash   String   @map("token_hash")   // bcrypt-hash av engangs-token
  expiresAt   DateTime @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("client_portal_invites")
}

/// Invitasjon fra org-owner til ny team-bruker (team-plan).
/// Mottakeren får e-post med engangs-token → setter passord → blir User
/// i samme Organization med valgt rolle (member eller admin).
///
/// Sikkerhet:
///   - Tokenet sendes kun i e-posten — vi lagrer bcrypt-hashen (DB-lekkasje
///     gir ikke aksept-tilgang). Samme mønster som ClientPortalInvite.
///   - 7 dagers utløp (expiresAt). Pending invites filtreres på expiresAt > now
///     i listings — utløpte ryddes av jobs/cleanup hvis vi legger til det.
///   - acceptedAt + acceptedByUserId settes ved aksept → invite er da brukt
///     opp og kan ikke aksepteres igjen (idempotent re-aksept feiler).
///   - @@unique([organizationId, email]) hindrer dupliserte aktive invites
///     mot samme epost i samme org. Re-invite må først DELETE den gamle.
model TeamInvite {
  id               String   @id @default(uuid())
  organizationId   String   @map("organization_id")
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedByUserId  String   @map("invited_by_user_id")
  invitedBy        User     @relation("InvitesSent", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  email            String
  role             UserRole @default(member)
  tokenHash        String   @map("token_hash")
  expiresAt        DateTime @map("expires_at")
  acceptedAt       DateTime? @map("accepted_at")
  acceptedByUserId String?  @map("accepted_by_user_id")
  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([organizationId, email])
  @@index([organizationId, acceptedAt])
  @@map("team_invites")
}

model Sak {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  clientId       String?   @map("client_id")          // null = intern sak (ikke fakturerbar)
  title          String
  saksnummer     String?   // eget saksnummer fra fagsystem (Holte/eByggesøk) eller fritekst
  description    String?   @db.Text
  status         SakStatus @default(ikke_pabegynt)
  deadline       DateTime?
  hourlyRate     Int?      @map("hourly_rate")        // overstyrer client/org-default
  folderPath     String?   @map("folder_path")        // lokal mappe på brukerens disk
  color          String?                              // hex-farge for visning i kanban
  archived       Boolean   @default(false)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  closedAt       DateTime? @map("closed_at")

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client         Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  matchingRules  MatchingRule[]
  timeEntries    TimeEntry[]
  milestones     Milestone[]
  emailLinks     EmailLink[]
  invoices       Invoice[]
  stickyNotes    StickyNote[]
  sharedLinks    SharedSakLink[]
  aiChatMessages AiChatMessage[]

  @@index([organizationId, status])
  @@index([organizationId, clientId])
  @@index([organizationId, archived])
  @@map("saker")
}

/// AI-chathistorikk per sak per bruker. Lar Claude huske konteksten innenfor
/// samme sak (men ikke på tvers av saker) — neste prompt får siste N meldinger
/// med, slik at oppfølgingsspørsmål gir mening. Slettes når sak eller bruker
/// slettes. Bruker kan også selv "starte ny samtale" via DELETE-endpoint.
model AiChatMessage {
  id             String   @id @default(uuid())
  sakId          String   @map("sak_id")
  sak            Sak      @relation(fields: [sakId], references: [id], onDelete: Cascade)
  userId         String   @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String   // "user" eller "assistant"
  content        String   @db.Text
  // For sporing: lagre token-bruk hvis assistant
  inputTokens    Int?     @map("input_tokens")
  outputTokens   Int?     @map("output_tokens")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([sakId, createdAt])
  @@map("ai_chat_messages")
}

model MatchingRule {
  id        String           @id @default(uuid())
  sakId     String           @map("sak_id")
  type      MatchingRuleType
  pattern   String           // regex eller substring, avhengig av type
  priority  Int              @default(0)              // høyere = matches først
  enabled   Boolean          @default(true)
  createdAt DateTime         @default(now()) @map("created_at")

  sak Sak @relation(fields: [sakId], references: [id], onDelete: Cascade)

  @@index([sakId])
  @@map("matching_rules")
}

model TimeEntry {
  id            String           @id @default(uuid())
  sakId         String?          @map("sak_id")       // null = ikke-matchet (må kategoriseres)
  userId        String           @map("user_id")
  startedAt     DateTime         @map("started_at")
  endedAt       DateTime         @map("ended_at")
  durationSec   Int              @map("duration_sec")
  source        TimeEntrySource  @default(auto)
  windowTitle   String?          @map("window_title")
  appName       String?          @map("app_name")
  filePath      String?          @map("file_path")
  deviceId      String?          @map("device_id")    // hvilket Sakspilot-installasjon
  billable      Boolean          @default(true)
  hourlyRate    Int?             @map("hourly_rate")  // snapshot ved fakturering
  note          String?          @db.Text
  invoiceId     String?          @map("invoice_id")   // satt når entry er fakturert
  // AI-triage — Claude foreslår sak når matching-regler ikke traff.
  // aiSuggestedSakId settes av POST /ai-triage/suggest, tømmes ved accept
  // (sakId settes da til foreslaget) eller hvis bruker rejecter.
  // aiSuggestionRejected hindrer at vi spør Claude på nytt om samme entry.
  aiSuggestedSakId      String?   @map("ai_suggested_sak_id")
  aiSuggestedAt         DateTime? @map("ai_suggested_at")
  aiSuggestionRejected  Boolean   @default(false) @map("ai_suggestion_rejected")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  sak     Sak?     @relation(fields: [sakId], references: [id], onDelete: SetNull)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([userId, startedAt])
  @@index([sakId, startedAt])
  @@index([invoiceId])
  @@map("time_entries")
}

model Milestone {
  id                 String    @id @default(uuid())
  sakId              String    @map("sak_id")
  title              String
  dueDate            DateTime  @map("due_date")
  completedAt        DateTime? @map("completed_at")
  notifyDaysBefore   Int       @default(7) @map("notify_days_before")
  notified7d         Boolean   @default(false) @map("notified_7d")
  notified1d         Boolean   @default(false) @map("notified_1d")
  createdAt          DateTime  @default(now()) @map("created_at")

  sak Sak @relation(fields: [sakId], references: [id], onDelete: Cascade)

  @@index([sakId, dueDate])
  @@map("milestones")
}

model EmailLink {
  id              String   @id @default(uuid())
  sakId           String   @map("sak_id")
  graphMessageId  String   @unique @map("graph_message_id")
  fromAddress     String   @map("from_address")
  toAddresses     String?  @map("to_addresses")     // kommaseparert
  subject         String?
  receivedAt      DateTime @map("received_at")
  isOutgoing      Boolean  @default(false) @map("is_outgoing")
  bodyPreview     String?  @map("body_preview") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  sak Sak @relation(fields: [sakId], references: [id], onDelete: Cascade)

  @@index([sakId, receivedAt])
  @@map("email_links")
}

model Invoice {
  id              String              @id @default(uuid())
  organizationId  String              @map("organization_id")
  sakId           String?             @map("sak_id")
  periodStart     DateTime            @map("period_start")
  periodEnd       DateTime            @map("period_end")
  totalHours      Decimal             @map("total_hours") @db.Decimal(10, 2)
  totalAmount     Decimal             @map("total_amount") @db.Decimal(12, 2)
  currency        String              @default("NOK")
  status          InvoiceStatus       @default(draft)
  exportedTo      InvoiceExportTarget? @map("exported_to")
  exportedAt      DateTime?           @map("exported_at")
  externalRef     String?             @map("external_ref")  // f.eks. Tripletex-ordrenummer
  note            String?             @db.Text
  // ── Felter for ekte faktura-utstedelse + import fra portal-hub ─────
  /// Fakturanummer (intern sekvens, f.eks. "3001"). Frivillig fordi
  /// noen orgs lar Fiken/Tripletex generere det og bare lagrer externalRef.
  invoiceNumber   String?             @map("invoice_number")
  /// Forfallsdato — vises på PDF og brukes av betalingspåminnelser
  dueDate         DateTime?           @map("due_date")
  /// Når fakturaen ble betalt (manuelt registrert eller via bankavstemming)
  paidAt          DateTime?           @map("paid_at")
  /// Kunde-navn snapshot — brukes når sakId/clientId er null (legacy/imported)
  customerName    String?             @map("customer_name")
  /// Kunde-adresse snapshot (kun for legacy import)
  customerAddress String?             @map("customer_address")
  /// Faktura-linjer som JSON: [{ description, quantity, unitPrice, sum }]
  /// Brukes for ekte faktura-PDF + import fra portal-hub. Ikke alle fakturaer
  /// har linjer (timesbaserte aggregeres fra timeEntries) — derfor nullable.
  lineItems       Json?               @map("line_items")
  /// Ekstern ID fra import-kilde (f.eks. "inv_3001" fra portal-hub).
  /// Brukes til idempotent upsert i seed-scriptene.
  externalId      String?             @map("external_id")
  /// Når fakturaen sist ble sendt på epost via Sakspilot (POST /invoices/:id/send-email).
  /// Null = aldri sendt fra Sakspilot (kan likevel være sendt manuelt utenfor).
  sentEmailAt     DateTime?           @map("sent_email_at")
  /// Mottakers epost-adresse (siste send). Vises i historikk.
  sentEmailTo     String?             @map("sent_email_to")
  /// Sist sendt purring (manuell eller via auto-cron). Brukes som debounce
  /// for cron-jobben — vi purrer ikke samme faktura mer enn én gang per uke.
  reminderSentAt  DateTime?           @map("reminder_sent_at")
  /// Antall purringer sendt totalt. Brukes for cron-eskalering (1. purring
  /// vennlig, 2. mer pressende, 3. siste).
  reminderCount   Int                 @default(0) @map("reminder_count")
  /// MVA-sats brukt på fakturaen. 25 = standard, 15 = mat, 12 = transport,
  /// 0 = ingen (utenlands, fritak). Default 25 fordi det er norsk standardsats.
  /// Frilansere under MVA-grensen (50k/år) skal sette dette til null på alle
  /// fakturaer FRA innstillingene — vi tvinger ikke det fra DB.
  mvaSats         Int?                @default(25) @map("mva_sats")
  /// Om totalAmount/lineItems.unitPrice er INKLUSIV MVA (true) eller eksklusiv (false).
  /// true = hub-konvensjon (pris inkl. MVA, MVA beregnes ut fra total)
  /// false = vanlig fakturering hvor MVA legges på toppen
  /// Default true matcher hva som importeres fra portal-hub.
  mvaInkludert    Boolean             @default(true) @map("mva_inkludert")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sak          Sak?         @relation(fields: [sakId], references: [id], onDelete: SetNull)
  timeEntries  TimeEntry[]

  @@unique([organizationId, externalId])
  @@index([organizationId, periodStart])
  @@index([organizationId, paidAt])
  @@map("invoices")
}

model AgentSession {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  deviceId      String        @map("device_id")           // stabil id per installasjon
  deviceName    String?       @map("device_name")         // f.eks. "Helene-PC"
  platform      AgentPlatform @default(windows)
  agentVersion  String        @map("agent_version")
  lastSeenAt    DateTime      @default(now()) @map("last_seen_at")
  isPaused      Boolean       @default(false) @map("is_paused")
  createdAt     DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
  @@map("agent_sessions")
}

model GraphAccount {
  id                String    @id @default(uuid())
  userId            String    @unique @map("user_id")
  microsoftId       String    @map("microsoft_id")
  email             String
  refreshToken      String    @map("refresh_token") @db.Text    // kryptert
  accessTokenExpiresAt DateTime? @map("access_token_expires_at")
  lastSyncAt        DateTime? @map("last_sync_at")
  scopes            String                                       // kommaseparert
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("graph_accounts")
}

enum AutomationTrigger {
  sak_status_changed      // når en sak skifter status
  sak_created             // når en ny sak opprettes
  milestone_completed     // når en milepæl markeres fullført
  milestone_due_soon      // når milepæl er N dager unna (sjekkes per request)
  time_entry_logged       // når desktop-agent synker tid (kommer)
}

enum AutomationAction {
  create_sticky           // opprett klistrelapp med custom tekst
  create_milestone        // opprett milepæl med offset i dager
  change_sak_status       // endre sak-status
  show_notification       // vis varsel på dashbord (kommer)
}

model Automation {
  id              String   @id @default(uuid())
  organizationId  String   @map("organization_id")
  name            String                                  // brukerens navn for agenten
  trigger         AutomationTrigger
  triggerConfig   Json     @map("trigger_config")         // f.eks. { fromStatus: "pagaaende", toStatus: "ferdig" }
  action          AutomationAction
  actionConfig    Json     @map("action_config")          // f.eks. { stickyText: "Send faktura til {clientName}", color: "yellow" }
  enabled         Boolean  @default(true)
  lastRunAt       DateTime? @map("last_run_at")
  runCount        Int      @default(0) @map("run_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, enabled, trigger])
  @@map("automations")
}

/// Offentlig delt visning av en sak — klient kan se status/milepæler
/// uten å logge inn. Token er kryptografisk tilfeldig (24 bytes base64url).
model SharedSakLink {
  id          String    @id @default(uuid())
  sakId       String    @map("sak_id")
  token       String    @unique                            // ugjettbar URL-token
  createdById String    @map("created_by_id")              // hvem genererte lenken
  expiresAt   DateTime? @map("expires_at")                 // null = aldri utløper
  viewCount   Int       @default(0) @map("view_count")
  lastViewedAt DateTime? @map("last_viewed_at")
  revokedAt   DateTime? @map("revoked_at")                 // soft-delete
  showTimeEntries Boolean @default(false) @map("show_time_entries")  // valgfritt: del timeoversikt
  createdAt   DateTime  @default(now()) @map("created_at")

  sak       Sak  @relation(fields: [sakId], references: [id], onDelete: Cascade)
  createdBy User @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([sakId, revokedAt])
  @@index([token])
  @@map("shared_sak_links")
}

model StickyNote {
  id              String   @id @default(uuid())
  organizationId  String   @map("organization_id")
  userId          String?  @map("user_id")
  sakId           String?  @map("sak_id")
  content         String   @db.Text
  color           String   @default("yellow")
  pinned          Boolean  @default(false)
  sortOrder       Int      @default(0) @map("sort_order")
  /// Valgfri påminnelse-tid. Når satt og <= now() vises et varsel
  /// (toast i web, native Notification i Electron). Null = ingen påminnelse.
  remindAt        DateTime? @map("remind_at")
  /// Dedupe-flagg — settes idet en påminnelse er vist for å hindre at
  /// samme klistrelapp gir gjentatte varsler ved hver poll. Nullstilles
  /// hvis brukeren setter en ny remindAt (f.eks. "Slumre 5 min").
  notifiedAt      DateTime? @map("notified_at")
  /// Voice note (stemmenotat) lagret som base64-encoded blob direkte i DB.
  /// MVP-tilnærming — ingen S3 nødvendig. Max 60 sek innspilling håndheves
  /// i frontend + via Zod-validering i API (ca 200 KB base64 = ~150 KB binary
  /// for opus@32kbps). Slettes ved å nullstille alle 4 felter via
  /// DELETE /stickies/:id/audio. Lagres KUN i bruker-organisasjonens DB,
  /// sendes aldri til klient-portal eller eksterne AI-providere.
  audioBase64     String?  @map("audio_base64") @db.Text
  audioDurationSec Int?    @map("audio_duration_sec")
  audioMimeType   String?  @map("audio_mime_type")
  audioRecordedAt DateTime? @map("audio_recorded_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  sak          Sak?         @relation(fields: [sakId], references: [id], onDelete: SetNull)

  @@index([organizationId, pinned, updatedAt])
  @@index([sakId])
  @@index([userId, remindAt, notifiedAt])
  @@map("sticky_notes")
}

model AuditLog {
  id              String   @id @default(uuid())
  userId          String?  @map("user_id")
  organizationId  String?  @map("organization_id")
  action          String                              // f.eks. "sak.created", "invoice.exported"
  entityType      String?  @map("entity_type")
  entityId        String?  @map("entity_id")
  ipAddress       String?  @map("ip_address")
  userAgent       String?  @map("user_agent")
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

/// Pilot-feedback fra brukere som tester Sakspilot.
/// Helene leser via Prisma Studio (eller liten admin-side senere).
/// Tre fritekst-felter + ønske om video-samtale.
model Feedback {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  organizationId  String   @map("organization_id")
  whatWorksBest   String?  @map("what_works_best")   // max 1000 (håndheves i route)
  whatFrustrates  String?  @map("what_frustrates")   // max 1000 (håndheves i route)
  whatIsMissing   String?  @map("what_is_missing")   // max 1000 (håndheves i route)
  wantsVideoCall  Boolean  @default(false) @map("wants_video_call")
  submittedAt     DateTime @default(now()) @map("submitted_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, submittedAt])
  @@index([userId, submittedAt])
  @@map("feedbacks")
}
